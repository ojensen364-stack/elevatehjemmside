# Discord OAuth2 Configuration
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id_here
DISCORD_CLIENT_SECRET=your_discord_client_secret_here

# NextAuth Configuration
NEXTAUTH_SECRET=your_random_secret_key_here_min_32_chars
NEXTAUTH_URL=http://localhost:3000

# Discord Redirect URI (for OAuth2)
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback/discord

# Discord Webhook URL for applications
WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Admin Discord IDs (comma-separated)
ADMIN_DISCORD_IDS=123456789012345678,987654321098765432
NEXT_PUBLIC_ADMIN_DISCORD_IDS=123456789012345678,987654321098765432
